<script>
  // ===== THEME =====
  function applyTheme(theme) {
    const root = document.getElementById('html-root');
    root.dataset.theme = theme;
    const icon = document.getElementById('theme-icon');
    const label = document.getElementById('theme-label');
    if (theme === 'dark') {
      icon.textContent = '\u2600\ufe0f';
      label.textContent = 'Light';
    } else {
      icon.textContent = '\uD83C\uDF19';
      label.textContent = 'Dark';
    }
    localStorage.setItem('voge-theme', theme);
  }

  function toggleTheme() {
    const current = document.getElementById('html-root').dataset.theme || 'dark';
    applyTheme(current === 'dark' ? 'light' : 'dark');
  }

  // Init theme from localStorage (dark by default)
  const savedTheme = localStorage.getItem('voge-theme') || 'dark';
  applyTheme(savedTheme);

  // ===== LANGUAGE =====
  function setLang(lang) {
    document.getElementById('html-root').dataset.lang = lang;
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.classList.toggle('active', btn.textContent.toLowerCase() === lang);
    });
    // Show/hide procedure list items by lang
    document.querySelectorAll('.procedure-list li.es').forEach(el => {
      el.style.display = lang === 'es' ? 'flex' : 'none';
    });
    document.querySelectorAll('.procedure-list li.en').forEach(el => {
      el.style.display = lang === 'en' ? 'flex' : 'none';
    });
    document.querySelectorAll('.procedure-list li.fr').forEach(el => {
      el.style.display = lang === 'fr' ? 'flex' : 'none';
    });
  }

  // Active sidebar nav on scroll
  const sections = document.querySelectorAll('section[id]');
  const navItems = document.querySelectorAll('.nav-item');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navItems.forEach(item => {
          item.classList.toggle('active', item.getAttribute('href') === '#' + entry.target.id);
        });
      }
    });
  }, { threshold: 0.3 });

  sections.forEach(s => observer.observe(s));

  // Init ES display
  setLang('es');
</script>

