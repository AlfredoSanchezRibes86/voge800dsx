---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const sections = [
  { slug: 'motor',         icon: '▶',  title: 'Motor & Arranque',   desc: 'Bicil. DOHC 798cc · 70 kW · 81 Nm' },
  { slug: 'aceite',        icon: '◈',  title: 'Aceite Motor',       desc: '3,2 L SAE 10W/40 · cada 5.000 km' },
  { slug: 'frenos',        icon: '⊗',  title: 'Frenos',             desc: 'Doble disco 310 mm · DOT4 · ABS 2 can.' },
  { slug: 'suspension',    icon: '↕',  title: 'Suspensión',         desc: 'Horquilla inv. 43 mm · 10 posiciones' },
  { slug: 'cadena',        icon: '⊞',  title: 'Cadena',             desc: '520SX2 × 122 eslab. · tensado' },
  { slug: 'apriete',       icon: '⊕',  title: 'Pares de apriete',   desc: 'Tabla completa de torques por zona' },
  { slug: 'refrigerante',  icon: '❄',  title: 'Refrigerante',       desc: '1,75 L · mezcla 50/50 G40' },
  { slug: 'mantenimiento', icon: '✓',  title: 'Mantenimiento',      desc: 'Tabla oficial 1.000 – 24.000 km' },
  { slug: 'electrico',     icon: '⚡', title: 'Eléctrico',          desc: '12V 10Ah · fusibles · bujía LMAR8J-9E' },
  { slug: 'performance',   icon: '🔥', title: 'Performance',        desc: 'Escape, ECU flash, neumáticos' },
  { slug: 'accesorios',    icon: '🧰', title: 'Accesorios',         desc: 'Protección, equipaje, ergonomía' },
  { slug: 'tiendas',       icon: '🛒', title: 'Tiendas & Repuestos', desc: 'AZMotors, distribuidores, Amazon' },
];
---
<Layout title="VOGE 800 DSX Rally — Guía Técnica">
<style>
  /* HERO */
  .hero {
    padding: 3rem 1.25rem 2.5rem;
    text-align: center;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }
  .hero-badge {
    display: inline-block;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-size: .72rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: 3px 12px;
    border-radius: 20px;
    margin-bottom: 1rem;
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -.03em;
    line-height: 1.1;
    margin-bottom: .5rem;
  }
  .hero h1 b { color: var(--accent); }
  .hero-sub {
    color: var(--text-muted);
    font-size: 1rem;
    margin-bottom: 2rem;
  }

  /* STATS STRIP */
  .stats {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    max-width: 640px;
    margin: 0 auto;
  }
  .stat {
    flex: 1 1 100px;
    padding: 1rem .75rem;
    text-align: center;
    border-right: 1px solid var(--border);
    background: var(--bg-card);
  }
  .stat:last-child { border-right: none; }
  .stat-val {
    display: block;
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -.02em;
  }
  .stat-label {
    display: block;
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--text-muted);
    margin-top: 2px;
  }

  /* GRID */
  .grid-wrap {
    max-width: 860px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem;
  }
  .grid-title {
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    font-weight: 600;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: .75rem;
  }
  .card-link {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem 1rem;
    text-decoration: none;
    color: var(--text);
    transition: border-color .15s, transform .15s, box-shadow .15s;
    gap: .5rem;
  }
  .card-link:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,.25);
    text-decoration: none;
  }
  .card-icon {
    font-size: 1.75rem;
    line-height: 1;
    color: var(--accent);
    margin-bottom: .25rem;
  }
  .card-title {
    font-weight: 700;
    font-size: .95rem;
    line-height: 1.2;
  }
  .card-desc {
    font-size: .78rem;
    color: var(--text-muted);
    line-height: 1.4;
  }
  .card-arrow {
    font-size: .78rem;
    color: var(--accent);
    margin-top: auto;
    padding-top: .5rem;
    font-weight: 600;
  }

  @media (max-width: 480px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
    .stat-val { font-size: 1.1rem; }
  }
</style>

<!-- HERO -->
<div class="hero">
  <div class="hero-badge">Guía Técnica Oficial</div>
  <h1>VOGE <b>800 DSX</b> Rally</h1>
  <p class="hero-sub">Manual técnico basado en documentación oficial Loncin · LX800-2</p>
  <div class="stats">
    <div class="stat"><span class="stat-val">798 cc</span><span class="stat-label">Cilindrada</span></div>
    <div class="stat"><span class="stat-val">95 CV</span><span class="stat-label">Potencia</span></div>
    <div class="stat"><span class="stat-val">81 Nm</span><span class="stat-label">Par máx.</span></div>
    <div class="stat"><span class="stat-val">210 km/h</span><span class="stat-label">V. máx.</span></div>
    <div class="stat"><span class="stat-val">227 kg</span><span class="stat-label">Peso</span></div>
    <div class="stat"><span class="stat-val">24 L</span><span class="stat-label">Depósito</span></div>
  </div>
</div>

<!-- GRID -->
<div class="grid-wrap">
  <p class="grid-title">Selecciona una sección</p>
  <div class="grid">
    {sections.map(s => (
      <a class="card-link" href={`${base}/${s.slug}`}>
        <div class="card-icon">{s.icon}</div>
        <div class="card-title">{s.title}</div>
        <div class="card-desc">{s.desc}</div>
        <div class="card-arrow">Ver sección →</div>
      </a>
    ))}
  </div>
</div>
</Layout>
