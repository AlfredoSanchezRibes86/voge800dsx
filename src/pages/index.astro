---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const sections = [
  { slug: 'motor',        icon: '▶',  title: 'Motor & Arranque',    desc: 'Bicilíndrico DOHC 798cc · 70kW · 81Nm' },
  { slug: 'aceite',       icon: '◈',  title: 'Aceite Motor',        desc: 'SAE 10W/40-SL · 3,2L · cada 5000km' },
  { slug: 'frenos',       icon: '⊗',  title: 'Frenos',              desc: 'Doble disco 310mm · DOT4 · ABS 2 canales' },
  { slug: 'suspension',   icon: '↕',  title: 'Suspensión',          desc: 'Horquilla invertida 43mm · 10 posiciones' },
  { slug: 'cadena',       icon: '⊞',  title: 'Cadena',              desc: '520SX2 × 122 eslabones · tensado' },
  { slug: 'apriete',      icon: '⊕',  title: 'Pares de Apriete',    desc: 'Tabla completa de torques oficiales' },
  { slug: 'refrigerante', icon: '❄',  title: 'Refrigerante',        desc: 'Capacidad 1,75L · mezcla al 50%' },
  { slug: 'mantenimiento',icon: '✓',  title: 'Mantenimiento',       desc: 'Tabla de intervalos 1000–24000km' },
  { slug: 'electrico',    icon: '⚡', title: 'Sistema Eléctrico',   desc: 'Batería 12V 10Ah · fusibles · bujía' },
  { slug: 'performance',  icon: '🔥', title: 'Performance',         desc: 'Mejoras y optimizaciones recomendadas' },
  { slug: 'accesorios',   icon: '🧰', title: 'Accesorios',          desc: 'Equipamiento por categorías' },
  { slug: 'tiendas',      icon: '🛒', title: 'Tiendas & Repuestos', desc: 'Dónde comprar piezas y accesorios' },
];
---
<Layout title="VOGE 800 DSX Rally — Guía Técnica">
  <style>
    .hero {
      background: linear-gradient(135deg, #0d1117 0%, #1a0a0a 100%);
      border-bottom: 2px solid #d32f2f;
      padding: 2.5rem 1.5rem 2rem;
      text-align: center;
    }
    [data-theme="light"] .hero {
      background: linear-gradient(135deg, #f5f5f5 0%, #ffe0e0 100%);
    }
    .hero-title {
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 0.3rem;
    }
    .hero-title span { color: #d32f2f; }
    .hero-subtitle {
      color: var(--text-muted);
      font-size: 1rem;
      margin-bottom: 1.5rem;
    }
    .stats {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .stat {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.75rem 1.25rem;
      text-align: center;
      min-width: 90px;
    }
    .stat-val {
      font-size: 1.4rem;
      font-weight: 700;
      color: #d32f2f;
    }
    .stat-label {
      font-size: 0.75rem;
      color: var(--text-faint);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .sections-grid {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 0 1.5rem;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1rem;
    }

    .section-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.5rem;
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.2s, background 0.2s, transform 0.15s;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .section-card:hover {
      border-color: #d32f2f;
      background: var(--bg-hover);
      transform: translateY(-2px);
      text-decoration: none;
      color: var(--text);
    }
    .card-icon { font-size: 2.2rem; line-height: 1; }
    .card-title { font-size: 1rem; font-weight: 700; }
    .card-desc { font-size: 0.83rem; color: var(--text-muted); line-height: 1.4; }
    .card-arrow {
      margin-top: auto;
      padding-top: 0.75rem;
      font-size: 0.82rem;
      color: #d32f2f;
      font-weight: 500;
    }

    @media (max-width: 480px) {
      .sections-grid { grid-template-columns: 1fr 1fr; gap: 0.75rem; }
      .section-card { padding: 1rem; }
    }
  </style>

  <div class="hero">
    <h1 class="hero-title">VOGE <span>800 DSX</span> Rally</h1>
    <p class="hero-subtitle">Guía técnica completa · Manual del propietario y taller</p>
    <div class="stats">
      <div class="stat"><div class="stat-val">798cc</div><div class="stat-label">Cilindrada</div></div>
      <div class="stat"><div class="stat-val">95CV</div><div class="stat-label">Potencia</div></div>
      <div class="stat"><div class="stat-val">81Nm</div><div class="stat-label">Par máx.</div></div>
      <div class="stat"><div class="stat-val">227kg</div><div class="stat-label">Peso</div></div>
    </div>
  </div>

  <div class="sections-grid">
    {sections.map(s => (
      <a class="section-card" href={`${base}${s.slug}`}>
        <div class="card-icon">{s.icon}</div>
        <div class="card-title">{s.title}</div>
        <div class="card-desc">{s.desc}</div>
        <div class="card-arrow">Ver sección →</div>
      </a>
    ))}
  </div>
</Layout>
