---
// VOGE 800 DSX Rally — Guía Técnica Completa
// Diseño inspirado en rieju307rally.es — sidebar lateral sticky, secciones con specs + procedimiento + despiece
---
<!DOCTYPE html>
<html lang="es" id="html-root">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>VOGE 800 DSX Rally — Guía Técnica</title>
  <meta name="description" content="Guía técnica completa para la VOGE 800 DSX Rally. Especificaciones, mantenimiento, frenos, suspensión y más." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    /* ===== THEME: DARK (default) ===== */
    :root, [data-theme="dark"] {
      --bg:           #0d1117;
      --bg-card:      #161b22;
      --bg-alt:       #1c2128;
      --bg-hover:     #21262d;
      --text:         #e6edf3;
      --text-muted:   #8b949e;
      --text-faint:   #6e7681;
      --border:       #30363d;
      --border-light: #21262d;
      --nav-active-bg: rgba(211,47,47,0.15);
      --table-header-bg: #21262d;
      --table-header-text: #e6edf3;
      --despiece-bg:  #161b22;
      --footer-bg:    #010409;
      --shadow:       rgba(0,0,0,0.4);
    }
    /* ===== THEME: LIGHT ===== */
    [data-theme="light"] {
      --bg:           #f8f9fa;
      --bg-card:      #ffffff;
      --bg-alt:       #f9fafb;
      --bg-hover:     #f3f4f6;
      --text:         #1a1a2e;
      --text-muted:   #6b7280;
      --text-faint:   #9ca3af;
      --border:       #e5e7eb;
      --border-light: #f3f4f6;
      --nav-active-bg: #fff3f3;
      --table-header-bg: #1a1a2e;
      --table-header-text: #ffffff;
      --despiece-bg:  #ffffff;
      --footer-bg:    #1a1a2e;
      --shadow:       rgba(0,0,0,0.06);
    }
    /* ===== RESET & BASE ===== */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      font-size: 15px;
      transition: background 0.25s, color 0.25s;
    }

    /* ===== LAYOUT ===== */
    .layout {
      display: flex;
      min-height: 100vh;
    }

    /* ===== SIDEBAR ===== */
    .sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      width: 72px;
      background: var(--bg-card);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 1.2rem 0;
      gap: 0.25rem;
      z-index: 200;
      overflow-y: auto;
      flex-shrink: 0;
      box-shadow: 2px 0 8px var(--shadow);
    }
    .sidebar-logo {
      font-size: 0.6rem;
      font-weight: 700;
      color: #d32f2f;
      text-align: center;
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 0.8rem;
      padding: 0 0.5rem;
      line-height: 1.2;
    }
    .sidebar-divider {
      width: 36px;
      height: 1px;
      background: var(--border);
      margin: 0.4rem 0;
    }
    .nav-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 3px;
      padding: 0.55rem 0.4rem;
      border-radius: 10px;
      cursor: pointer;
      text-decoration: none;
      color: var(--text-muted);
      transition: all 0.2s;
      width: 58px;
      text-align: center;
    }
    .nav-item:hover, .nav-item.active {
      background: var(--nav-active-bg);
      color: #e53935;
    }
    .nav-item .icon {
      font-size: 1.3rem;
      line-height: 1;
    }
    .nav-item .label {
      font-size: 0.52rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      line-height: 1.2;
    }

    /* ===== MAIN CONTENT ===== */
    .main {
      flex: 1;
      overflow-x: hidden;
    }

    /* ===== TOP BAR ===== */
    .topbar {
      background: var(--bg-card);
      border-bottom: 1px solid var(--border);
      padding: 0.75rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .topbar-title {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .topbar-title span { color: #d32f2f; }
    .lang-selector {
      display: flex;
      gap: 6px;
    }
    .lang-btn {
      padding: 4px 12px;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--bg-alt);
      color: var(--text-muted);
      cursor: pointer;
      font-size: 0.78rem;
      font-weight: 500;
      font-family: inherit;
      transition: all 0.2s;
    }
    .lang-btn.active, .lang-btn:hover {
      background: #d32f2f;
      border-color: #d32f2f;
      color: white;
    }

    /* ===== HERO ===== */
    .hero {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
      color: white;
      padding: 4rem 3rem;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="80" cy="20" r="60" fill="rgba(211,47,47,0.08)"/></svg>') no-repeat right center / 600px;
    }
    .hero-inner { position: relative; max-width: 900px; }
    .hero-badge {
      display: inline-block;
      padding: 3px 12px;
      background: rgba(211,47,47,0.2);
      border: 1px solid rgba(211,47,47,0.4);
      border-radius: 20px;
      font-size: 0.7rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #ff6b6b;
      margin-bottom: 1.2rem;
    }
    .hero h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 700;
      line-height: 1.1;
      margin-bottom: 0.5rem;
    }
    .hero h1 span { color: #ef5350; }
    .hero-subtitle {
      font-size: 1rem;
      color: rgba(255,255,255,0.6);
      margin-bottom: 2.5rem;
    }
    .hero-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .stat {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 1rem 1.4rem;
      min-width: 110px;
      transition: background 0.2s;
    }
    .stat:hover { background: rgba(255,255,255,0.1); }
    .stat-value {
      font-size: 1.6rem;
      font-weight: 700;
      color: white;
      line-height: 1;
    }
    .stat-unit { font-size: 0.85rem; color: rgba(255,255,255,0.5); }
    .stat-label { font-size: 0.7rem; color: rgba(255,255,255,0.4); margin-top: 0.2rem; text-transform: uppercase; letter-spacing: 1px; }

    /* ===== SECTIONS ===== */
    .content { padding: 0; }

    .section {
      padding: 3rem 3rem;
      border-bottom: 1px solid var(--border);
      background: var(--bg-card);
    }
    .section:nth-child(even) { background: var(--bg-alt); }

    .section-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .section-icon {
      width: 48px;
      height: 48px;
      background: var(--nav-active-bg);
      border: 1px solid rgba(211,47,47,0.25);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      flex-shrink: 0;
    }
    .section-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text);
    }
    .section-title-en { display: none; }
    .section-title-fr { display: none; }

    .section-body {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      align-items: start;
    }
    .section-body.full-width {
      grid-template-columns: 1fr;
    }
    .section-body.three-col {
      grid-template-columns: 1fr 1fr 1fr;
    }

    /* ===== SPECS TABLE ===== */
    .specs-block h3 {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #d32f2f;
      font-weight: 600;
      margin-bottom: 0.75rem;
    }
    .specs-table {
      width: 100%;
      border-collapse: collapse;
    }
    .specs-table tr { border-bottom: 1px solid var(--border-light); }
    .specs-table tr:last-child { border-bottom: none; }
    .specs-table td {
      padding: 0.5rem 0.25rem;
      font-size: 0.875rem;
      vertical-align: top;
    }
    .specs-table td:first-child {
      color: var(--text-muted);
      width: 45%;
      font-weight: 500;
    }
    .specs-table td:last-child {
      color: var(--text);
      font-weight: 600;
    }

    /* ===== PROCEDURE ===== */
    .procedure-block h3 {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #d32f2f;
      font-weight: 600;
      margin-bottom: 0.75rem;
    }
    .procedure-list {
      list-style: none;
      counter-reset: step;
    }
    .procedure-list li {
      counter-increment: step;
      display: flex;
      gap: 0.75rem;
      padding: 0.5rem 0;
      border-bottom: 1px solid var(--border-light);
      font-size: 0.875rem;
      align-items: flex-start;
    }
    .procedure-list li:last-child { border-bottom: none; }
    .procedure-list li::before {
      content: counter(step);
      background: #d32f2f;
      color: white;
      font-size: 0.7rem;
      font-weight: 700;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 1px;
    }

    /* ===== ALERT BOX ===== */
    .alert {
      padding: 0.75rem 1rem;
      border-radius: 8px;
      font-size: 0.82rem;
      margin-top: 1rem;
      display: flex;
      gap: 0.5rem;
      align-items: flex-start;
    }
    .alert-warning { background: #fef3c7; border-left: 3px solid #f59e0b; color: #92400e; }
    .alert-info { background: #eff6ff; border-left: 3px solid #3b82f6; color: #1e40af; }
    .alert-danger { background: #fef2f2; border-left: 3px solid #ef4444; color: #991b1b; }

    /* ===== DESPIECE IMAGE ===== */
    .despiece-block h3 {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #d32f2f;
      font-weight: 600;
      margin-bottom: 0.75rem;
    }
    .despiece-img {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      background: var(--despiece-bg);
    }
    .despiece-img img {
      width: 100%;
      height: auto;
      display: block;
    }
    .despiece-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      margin-top: 0.75rem;
      padding: 0.5rem 1rem;
      background: #d32f2f;
      color: white;
      border-radius: 8px;
      font-size: 0.8rem;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.2s;
    }
    .despiece-link:hover { background: #b71c1c; }

    /* ===== TORQUE TABLE ===== */
    .torque-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
    }
    .torque-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem;
    }
    .torque-card .torque-part {
      font-size: 0.8rem;
      color: var(--text-muted);
      margin-bottom: 0.25rem;
    }
    .torque-card .torque-value {
      font-size: 1.4rem;
      font-weight: 700;
      color: #d32f2f;
      line-height: 1;
    }
    .torque-card .torque-unit {
      font-size: 0.75rem;
      color: var(--text-faint);
    }

    /* ===== MAINTENANCE SCHEDULE ===== */
    .maint-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }
    .maint-table th {
      background: var(--table-header-bg);
      color: var(--table-header-text);
      padding: 0.6rem 0.75rem;
      text-align: left;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.5px;
    }
    .maint-table td {
      padding: 0.5rem 0.75rem;
      border-bottom: 1px solid var(--border-light);
    }
    .maint-table tr:nth-child(even) td { background: var(--bg-alt); }
    .maint-table .check { color: #16a34a; font-weight: 700; text-align: center; }
    .maint-table .replace { color: #d32f2f; font-weight: 700; text-align: center; }
    .maint-table .inspect { color: #d97706; font-weight: 700; text-align: center; }

    /* ===== ACCESORIOS GRID ===== */
    .acc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
    }
    .acc-card {
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.2rem;
      background: var(--bg-card);
    }
    .acc-card .acc-icon { font-size: 2rem; margin-bottom: 0.5rem; }
    .acc-card .acc-name { font-size: 0.9rem; font-weight: 600; color: var(--text); }
    .acc-card .acc-desc { font-size: 0.78rem; color: var(--text-muted); margin-top: 0.25rem; }

    /* ===== TIENDAS ===== */
    .tiendas-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1rem;
    }
    .tienda-card {
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.2rem;
      background: var(--bg-card);
    }
    .tienda-card .tienda-flag { font-size: 1.5rem; margin-bottom: 0.4rem; }
    .tienda-card .tienda-name { font-size: 1rem; font-weight: 700; color: var(--text); }
    .tienda-card .tienda-url {
      font-size: 0.8rem;
      color: #d32f2f;
      text-decoration: none;
      word-break: break-all;
    }
    .tienda-card .tienda-url:hover { text-decoration: underline; }
    .tienda-card .tienda-desc { font-size: 0.78rem; color: var(--text-muted); margin-top: 0.25rem; }

    /* ===== FOOTER ===== */
    .footer {
      background: var(--footer-bg);
      color: rgba(255,255,255,0.5);
      text-align: center;
      padding: 2rem;
      font-size: 0.8rem;
    }
    .footer a { color: #ef5350; text-decoration: none; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 900px) {
      .sidebar { display: none; }
      .topbar { padding: 0.75rem 1rem; }
      .hero { padding: 2.5rem 1.5rem; }
      .section { padding: 2rem 1.5rem; }
      .section-body { grid-template-columns: 1fr; }
      .section-body.three-col { grid-template-columns: 1fr; }
    }

    /* ===== THEME TOGGLE BUTTON ===== */
    .theme-toggle {
      padding: 4px 10px;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--bg-alt);
      color: var(--text-muted);
      cursor: pointer;
      font-size: 0.78rem;
      font-weight: 500;
      font-family: inherit;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .theme-toggle:hover {
      background: var(--bg-hover);
      color: var(--text);
    }
    /* ===== I18N ===== */
    [data-lang="en"] .es { display: none; }
    [data-lang="en"] .en { display: block; }
    [data-lang="en"] .en-inline { display: inline; }
    [data-lang="en"] .es-inline { display: none; }
    [data-lang="fr"] .es { display: none; }
    [data-lang="fr"] .fr { display: block; }
    [data-lang="fr"] .fr-inline { display: inline; }
    [data-lang="fr"] .es-inline { display: none; }
    .en { display: none; }
    .fr { display: none; }
    .en-inline { display: none; }
    .fr-inline { display: none; }
    .es-inline { display: inline; }
    [data-lang="en"] .en-inline { display: inline; }
    [data-lang="fr"] .fr-inline { display: inline; }
  </style>
</head>
<body>

<div class="layout" id="html-root">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-logo">VOGE<br/>800 DSX</div>
    <div class="sidebar-divider"></div>
    <a class="nav-item" href="#arranque" title="Arranque">
      <span class="icon">🔑</span>
      <span class="label">Arranque</span>
    </a>
    <a class="nav-item" href="#aceite" title="Aceite">
      <span class="icon">🛢️</span>
      <span class="label">Aceite</span>
    </a>
    <a class="nav-item" href="#frenos" title="Frenos">
      <span class="icon">🛑</span>
      <span class="label">Frenos</span>
    </a>
    <a class="nav-item" href="#suspension" title="Suspensión">
      <span class="icon">↕</span>
      <span class="label">Suspensión</span>
    </a>
    <a class="nav-item" href="#cadena" title="Cadena">
      <span class="icon">⛓️</span>
      <span class="label">Cadena</span>
    </a>
    <a class="nav-item" href="#pares" title="Pares apriete">
      <span class="icon">🔩</span>
      <span class="label">Pares</span>
    </a>
    <a class="nav-item" href="#refrigerante" title="Refrigerante">
      <span class="icon">❄</span>
      <span class="label">Refriger.</span>
    </a>
    <a class="nav-item" href="#mantenimiento" title="Mantenimiento">
      <span class="icon">🔧</span>
      <span class="label">Mant.</span>
    </a>
    <a class="nav-item" href="#electrico" title="Eléctrico">
      <span class="icon">⚡</span>
      <span class="label">Eléctrico</span>
    </a>
    <a class="nav-item" href="#performance" title="Performance">
      <span class="icon">🏁</span>
      <span class="label">Perf.</span>
    </a>
    <a class="nav-item" href="#accesorios" title="Accesorios">
      <span class="icon">🎒</span>
      <span class="label">Acces.</span>
    </a>
    <a class="nav-item" href="#tiendas" title="Tiendas">
      <span class="icon">🏪</span>
      <span class="label">Tiendas</span>
    </a>
  </aside>

  <!-- MAIN -->
  <div class="main">

    <!-- TOPBAR -->
    <div class="topbar">
      <div class="topbar-title">
        VOGE <span>800 DSX Rally</span> &mdash;
        <span class="es-inline">Guía Técnica</span>
        <span class="en-inline">Technical Guide</span>
        <span class="fr-inline">Guide Technique</span>
      </div>
      <div style="display:flex;align-items:center;gap:0.5rem">
        <button class="theme-toggle" id="theme-toggle" onclick="toggleTheme()" title="Cambiar tema">
          <span id="theme-icon">☀️</span>
          <span id="theme-label">Light</span>
        </button>
        <div class="lang-selector">
        <button class="lang-btn active" onclick="setLang('es')">ES</button>
        <button class="lang-btn" onclick="setLang('en')">EN</button>
        </div>
      </div>
    </div>

    <!-- HERO -->
    <div class="hero">
      <div class="hero-inner">
        <div class="hero-badge">
          <span class="es-inline">Guía Técnica Oficial</span>
          <span class="en-inline">Official Technical Guide</span>
          <span class="fr-inline">Guide Technique Officiel</span>
        </div>
        <h1>VOGE 800 <span>DSX Rally</span></h1>
        <p class="hero-subtitle">
          <span class="es">Motor bicilíndrico DOHC · Euro5+ · 2023–2025</span>
          <span class="en">Twin cylinder DOHC engine · Euro5+ · 2023–2025</span>
          <span class="fr">Moteur bicylindre DOHC · Euro5+ · 2023–2025</span>
        </p>
        <div class="hero-stats">
          <div class="stat">
            <div class="stat-value">798</div>
            <div class="stat-unit">cc</div>
            <div class="stat-label">
              <span class="es-inline">Cilindrada</span>
              <span class="en-inline">Displacement</span>
              <span class="fr-inline">Cylindrée</span>
            </div>
          </div>
          <div class="stat">
            <div class="stat-value">95</div>
            <div class="stat-unit">CV</div>
            <div class="stat-label">
              <span class="es-inline">Potencia</span>
              <span class="en-inline">Power</span>
              <span class="fr-inline">Puissance</span>
            </div>
          </div>
          <div class="stat">
            <div class="stat-value">81</div>
            <div class="stat-unit">Nm</div>
            <div class="stat-label">
              <span class="es-inline">Par motor</span>
              <span class="en-inline">Torque</span>
              <span class="fr-inline">Couple</span>
            </div>
          </div>
          <div class="stat">
            <div class="stat-value">210</div>
            <div class="stat-unit">km/h</div>
            <div class="stat-label">
              <span class="es-inline">Vel. máx.</span>
              <span class="en-inline">Top speed</span>
              <span class="fr-inline">Vit. max.</span>
            </div>
          </div>
          <div class="stat">
            <div class="stat-value">227</div>
            <div class="stat-unit">kg</div>
            <div class="stat-label">
