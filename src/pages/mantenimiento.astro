---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Mantenimiento — VOGE 800 DSX" description="Tabla de intervalos de mantenimiento periódico VOGE 800 DSX Rally">
  <div class="main-content">
    <nav class="breadcrumb">
      <a href={base}>Inicio</a>
      <span class="breadcrumb-sep">›</span>
      <span>Mantenimiento</span>
    </nav>

    <div class="page-actions">
      <a href={base} class="btn btn-back">← Volver</a>
      <a href="https://www.azmotors.fr/PIECES_VOGE/800_RALLY/vue-eclate-800DS-RALLY-EURO5.html" target="_blank" class="btn btn-ext">Ver despiece completo →</a>
    </div>

    <div class="section-header">
      <div class="section-icon">✓</div>
      <h1>Tabla de Mantenimiento</h1>
    </div>

    <img src={`${base}images/mantenimiento.jpg`} alt="Tabla de mantenimiento VOGE 800 DSX" class="section-image" />

    <div class="card">
      <h2>Período de rodaje (0 – 1.000 km)</h2>
      <ul style="padding-left:1.2rem; color:var(--text-muted); font-size:0.92rem; line-height:1.9;">
        <li>Evita revoluciones superiores al 60% durante los primeros 500 km</li>
        <li>No mantengas velocidad constante durante períodos largos</li>
        <li>A los 1.000 km: cambio de aceite y filtro obligatorio (aceite de rodaje)</li>
        <li>A los 1.000 km: inspección general completa en taller</li>
      </ul>
    </div>

    <div class="card">
      <h2>Intervalos de mantenimiento periódico</h2>
      <div style="overflow-x:auto;">
        <table>
          <thead>
            <tr>
              <th>Operación</th>
              <th>1.000</th>
              <th>5.000</th>
              <th>10.000</th>
              <th>15.000</th>
              <th>20.000</th>
              <th>24.000</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Cambio aceite motor</td><td>✓</td><td>✓</td><td>✓</td><td>✓</td><td>✓</td><td>✓</td></tr>
            <tr><td>Filtro de aceite</td><td>✓</td><td>✓</td><td>✓</td><td>✓</td><td>✓</td><td>✓</td></tr>
            <tr><td>Inspección cadena</td><td>✓</td><td>✓</td><td>✓</td><td>✓</td><td>✓</td><td>✓</td></tr>
            <tr><td>Tensado cadena</td><td>●</td><td>●</td><td>●</td><td>●</td><td>●</td><td>●</td></tr>
            <tr><td>Lubricación cadena</td><td colspan="6" style="text-align:center;color:var(--text-muted)">Cada 500 km o tras lluvia/barro</td></tr>
            <tr><td>Filtro de aire</td><td>—</td><td>I</td><td>S</td><td>I</td><td>S</td><td>I</td></tr>
            <tr><td>Bujías</td><td>—</td><td>I</td><td>S</td><td>I</td><td>S</td><td>I</td></tr>
            <tr><td>Líquido de frenos</td><td>—</td><td>I</td><td>S</td><td>I</td><td>S</td><td>—</td></tr>
            <tr><td>Pastillas de freno</td><td>—</td><td>I</td><td>I</td><td>I</td><td>I</td><td>I</td></tr>
            <tr><td>Neumáticos (desgaste)</td><td>I</td><td>I</td><td>I</td><td>I</td><td>I</td><td>I</td></tr>
            <tr><td>Refrigerante</td><td>—</td><td>—</td><td>—</td><td>—</td><td>S</td><td>—</td></tr>
            <tr><td>Juego válvulas</td><td>—</td><td>—</td><td>I</td><td>—</td><td>I</td><td>—</td></tr>
            <tr><td>Correa distribución</td><td colspan="6" style="text-align:center;color:var(--text-muted)">N/A (cadena de distribución)</td></tr>
            <tr><td>Rodamientos de rueda</td><td>—</td><td>—</td><td>I</td><td>—</td><td>I</td><td>—</td></tr>
            <tr><td>Cojinetes dirección</td><td>—</td><td>—</td><td>I</td><td>—</td><td>I</td><td>—</td></tr>
          </tbody>
        </table>
      </div>
      <p style="font-size:0.8rem; color:var(--text-faint); margin-top:0.5rem;">✓ = Realizar · I = Inspeccionar · S = Sustituir · ● = Ajustar si necesario · — = No aplica</p>
    </div>

    <div class="card">
      <h2>Revisiones anuales (independiente del km)</h2>
      <ul style="padding-left:1.2rem; color:var(--text-muted); font-size:0.92rem; line-height:1.9;">
        <li>Inspección visual de latiguillos de freno (cada 2 años sustituir)</li>
        <li>Cambio de refrigerante (cada 2 años)</li>
        <li>Verificación del sistema ABS y TCS</li>
        <li>Actualización de firmware del cuadro TFT si disponible</li>
      </ul>
    </div>

    <div style="margin-top:1rem; display:flex; gap:0.75rem; flex-wrap:wrap;">
      <a href={base} class="btn btn-back">← Volver al inicio</a>
      <a href="https://www.azmotors.fr/PIECES_VOGE/800_RALLY/vue-eclate-800DS-RALLY-EURO5.html" target="_blank" class="btn btn-ext">Ver despiece completo →</a>
    </div>
  </div>
</Layout>
